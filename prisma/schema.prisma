// Prisma schema for State Subsidies Discovery Platform
// PostgreSQL for production (Vercel Postgres / Supabase / etc.)

generator client {
  provider      = "prisma-client-js"
  // Vercel migrated functions from Debian to Amazon Linux 2 (RHEL-based).
  // Both targets are bundled so deploys work regardless of runtime.
  binaryTargets = ["native", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// SS-003: parse quality signal. LOW rows are filtered from the AI advisor (SS-008).
enum ParseConfidence {
  HIGH
  MEDIUM
  LOW
}

model Incentive {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Core identification
  title String
  slug  String @unique

  // Jurisdiction
  // Values: FEDERAL | STATE | CITY | AGENCY
  jurisdictionLevel String
  jurisdictionName  String // e.g. "California", "United States", "Los Angeles"

  // Agency
  managingAgency String
  agencyAcronym  String? // e.g. "CARB", "DOE"

  // Content
  shortSummary    String
  detailedSummary String?  // optional long-form description shown on detail pages
  keyRequirements String[]

  // Classification
  industryCategories String[]
  // Values: GRANT | TAX_CREDIT | POINT_OF_SALE_REBATE | SUBSIDY | LOAN | VOUCHER
  incentiveType      String

  // Funding details (optional)
  fundingAmount Float?
  deadline      DateTime?
  applicationOpenDate DateTime?

  // Source
  sourceUrl    String
  sourceDomain String  @default("") @db.VarChar(253) // hostname only; indexed for Trust Ribbon .gov count
  programCode  String? // official government program code

  // SS-003: provenance + quality
  sourceHash      String?         @db.Char(64)    // SHA-256 hex of stripped HTML; null until scraper emits it
  parseConfidence ParseConfidence @default(MEDIUM)
  parseNotes      String?                         // human-readable reason for MEDIUM/LOW
  lastVerifiedAt  DateTime?
  lastVerifiedBy  String?         @db.VarChar(64) // reviewer handle + role, e.g. "RQ (SME)"
  firstSeenAt     DateTime        @default(now())
  lastSeenAt      DateTime        @default(now())

  // Status: ACTIVE | CLOSED | UPCOMING | SUSPENDED
  status     String  @default("ACTIVE")
  isVerified Boolean @default(false)

  // Scraper metadata
  scrapedAt     DateTime?
  scraperSource String? // which scraper last updated this

  @@index([jurisdictionLevel])
  @@index([incentiveType])
  @@index([status])
  @@index([deadline])
  @@index([sourceDomain])
  @@index([parseConfidence])
  // Audit findings: filters/sorts that previously did sequential scans
  @@index([jurisdictionName])
  @@index([isVerified])
  @@index([fundingAmount])
  @@index([status, jurisdictionLevel])
  @@index([status, parseConfidence])
  // GIN index on TEXT[] for has/hasSome (@>, &&). Required for industryCategory filters.
  @@index([industryCategories(ops: ArrayOps)], type: Gin, map: "Incentive_industryCategories_gin")
}

model PageView {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  type      String   // pageview | query | click
  vid       String   // visitor ID
  page      String
  ref       String   @default("direct")
  query     String?  // search query if type=query

  @@index([createdAt])
  @@index([type])
}

model ScrapeRun {
  id                    String   @id @default(cuid())
  source                String
  startedAt             DateTime
  finishedAt            DateTime
  status                String   // SUCCESS | FAIL | PARTIAL
  rowsConsidered        Int
  rowsInserted          Int
  rowsUpdated           Int
  rowsSkipped           Int
  qualityGateRejections Int
  durationMs            Int
  notes                 String?

  @@index([source, finishedAt])
}
