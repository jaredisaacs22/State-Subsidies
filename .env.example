# ─── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL is required (locally and in production).
# Local dev: spin up postgres or use a free cloud DB (e.g. Vercel Postgres, Supabase)
DATABASE_URL="postgresql://user:password@localhost:5432/subsidies?schema=public"

# Direct/unpooled connection — required for:
#   • prisma migrate deploy during vercel-build
#   • Initialize Database GitHub Action
#   • Scraper GitHub Actions
# Source: Vercel → Storage → DB → .env.local → POSTGRES_URL_NON_POOLING
#         (or your provider's equivalent non-pooled URL)
DATABASE_URL_UNPOOLED="postgresql://user:password@host:5432/subsidies?schema=public"

# ─── AI Advisor (SS-008) ─────────────────────────────────────────────────────
# Required for /api/chat. Omit or leave blank to disable AI suggestions.
# Source: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY="your_api_key_here"

# Optional: override the Anthropic API base URL (e.g. for proxies or staging)
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# ─── Analytics API ───────────────────────────────────────────────────────────
# Required to access /api/analytics. Any non-empty string works locally.
DASHBOARD_SECRET="change-me-in-production"

# ─── Rate limiting (Redis — optional) ───────────────────────────────────────
# Upstash Redis credentials for distributed rate limiting (multi-region).
# Leave blank to use the in-process Map store (safe for single-instance dev).
# Source: https://console.upstash.com → Redis → REST API
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_token_here

# ─── Scraper ─────────────────────────────────────────────────────────────────
# Set to "false" to run live scrapers instead of mock data
SCRAPER_MOCK_MODE=true
